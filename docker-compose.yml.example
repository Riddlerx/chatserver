version: '3.8'

services:
  db:
    image: postgres:16
    container_name: chatserver-db
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: ${DB_PASSWORD}  # Set via .env or environment variables
      POSTGRES_DB: chatserver
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - chatserver_network

  app:
    build: .
    container_name: chatserver-app
    environment:
      - NODE_ENV=production
      - PORT=3000
      - DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@db:5432/chatserver
      - JWT_SECRET=${JWT_SECRET}  # Generate a strong random secret
      - CORS_ORIGINS=${CORS_ORIGINS:-http://localhost:5173}
    ports:
      - "3000:3000"
    depends_on:
      - db
    networks:
      - chatserver_network
    restart: unless-stopped

  frontend:
    build: ./frontend
    container_name: chatserver-frontend
    ports:
      - "5173:5173"
    environment:
      - VITE_API_URL=http://localhost:3000
    depends_on:
      - app
    networks:
      - chatserver_network

volumes:
  postgres_data:

networks:
  chatserver_network:
    driver: bridge
