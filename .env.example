# JWT Secret for authentication (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-here

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost,http://168.138.212.140:3000,http://168.138.212.140

# Database path (optional, defaults to ./chat.db)
DB_PATH=./chat.db

# Server port (optional, defaults to 3000)
PORT=3000
